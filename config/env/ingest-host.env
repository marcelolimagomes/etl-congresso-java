# Execução Java no host + PostgreSQL no container
APP_BASE_URL=http://localhost:8090

# Credenciais da API admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Banco no container (porta publicada no host)
DB_MODE=container
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/etl_congresso
SPRING_DATASOURCE_USERNAME=etl_user
SPRING_DATASOURCE_PASSWORD=etl_pass

# Inicialização local do Java
START_JAVA_APP=true
KEEP_APP_RUNNING=true
SPRING_PROFILE=local

# APIs externas
ETL_CAMARA_BASE_URL=https://dadosabertos.camara.leg.br
ETL_CAMARA_CSV_BASE_URL=https://dadosabertos.camara.leg.br/arquivos
ETL_SENADO_BASE_URL=https://legis.senado.leg.br
