# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Copie para .env e configure os valores
# NUNCA commite o .env no repositório
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=etl_congresso
POSTGRES_USER=etl_user
POSTGRES_PASSWORD=etl_pass_segura_aqui
POSTGRES_PORT=5432

# ── Aplicação ─────────────────────────────────────────────────────────────────
APP_PORT=8080
APP_PROFILE=prod

# ── ETL — URLs das APIs ───────────────────────────────────────────────────────
ETL_CAMARA_BASE_URL=https://dadosabertos.camara.leg.br
ETL_CAMARA_CSV_BASE_URL=https://dadosabertos.camara.leg.br/arquivos
ETL_SENADO_BASE_URL=https://legis.senado.leg.br
ETL_SENADO_ENRICH_URL_TEXTO=false
ETL_CSV_TMP_DIR=/tmp/etl/camara

# ── ETL — Scheduler ──────────────────────────────────────────────────────────
ETL_SCHEDULER_ENABLED=true
# Cron: Câmara às 02:00 e Senado às 03:00 (America/Sao_Paulo)
ETL_SCHEDULER_CRON_CAMARA=0 0 2 * * *
ETL_SCHEDULER_CRON_SENADO=0 0 3 * * *

# ── Segurança ─────────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=senha_forte_aqui

# ── Adminer ───────────────────────────────────────────────────────────────────
ADMINER_PORT=8081
